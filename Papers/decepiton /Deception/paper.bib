	keywords = {Computer Science - Artificial Intelligence, Computer Science - Human-Computer Interaction, Computer Science - Computers and Society},
	annote = {Comment: 18 pages (not including executive summary, references, and appendix), six figures},
	file = {arXiv Fulltext PDF:files/8101/Park et al. - 2023 - AI Deception A Survey of Examples, Risks, and Pot.pdf:application/pdf;arXiv.org Snapshot:files/8102/2308.html:text/html},
}

@misc{mazeikaHarmBenchStandardizedEvaluation2024,
	title = {{HarmBench}: {A} {Standardized} {Evaluation} {Framework} for {Automated} {Red} {Teaming} and {Robust} {Refusal}},
